{
  "[javascript]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    },
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[javascriptreact]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    },
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[python]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    },
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    },
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescriptreact]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    },
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "editor.minimap.enabled": false,
  "eslint.debug": true,
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "json",
    "jsonc",
    "typescript",
    "typescriptreact",
  ],
  "explorer.compactFolders": false,
  "explorer.expandSingleFolderWorkspaces": false,
  "files.associations": {
    "**/packages/tool-task-js/templates/**/*": "plaintext"
  },
  "files.autoSave": "afterDelay",
  "javascript.preferences.importModuleSpecifier": "non-relative",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "mypy-type-checker.enabled": true,
  "mypy-type-checker.importStrategy": "fromEnvironment",
  "mypy-type-checker.interpreter": [
    "${workspaceFolder}/packages/service-main-py/.venv/bin/python"
  ],
  "mypy-type-checker.reportingScope": "workspace",
  "pylint.interpreter": [
    "${workspaceFolder}/packages/service-main-py/.venv/bin/python"
  ],
  "python.analysis.autoImportCompletions": true,
  "python.analysis.enablePytestSupport": false,
  "python.analysis.indexing": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.typeCheckingMode": "basic",
  "python.defaultInterpreterPath": "${workspaceFolder}/packages/service-main-py/.venv/bin/python",
  "pylint.importStrategy": "fromEnvironment",
  "pylint.interpreter": [
    "${workspaceFolder}/packages/service-main-py/.venv/bin/python"
  ],
  "ruff.nativeServer": "auto",
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "workbench.colorTheme": "Default Dark+",
  "workbench.iconTheme": "vs-minimal",
  "workbench.sideBar.location": "right",
  "cursor.composer.suggestNextPrompt": true,
  "python-envs.defaultEnvManager": "ms-python.python:system",
  "cursorpyright.analysis.autoImportCompletions": true,
  "cursorpyright.analysis.inlayHints.functionReturnTypes": true,
  "cursorpyright.analysis.typeCheckingMode": "basic"
}